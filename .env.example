# Copy values into your shell or a local ignored .env loader of your choice.
# The application itself reads environment variables and does not auto-load this file.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_CHAT_MODEL=deepseek-v4-flash
LLM_JSON_RESPONSE_FORMAT=true
LLM_STREAMING=true
LLM_CONTEXT_WINDOW=131072
LLM_MAX_OUTPUT_TOKENS=4096
RUN_REAL_LLM_TESTS=false
